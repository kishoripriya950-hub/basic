// Intersection of two sorted array (Optimal code)
#include <bits/stdc++.h>
using namespace std;
vector<int> findArrayIntersection(vector<int> &A, int n, vector<int> &B, int m) {
    int i = 0;
    int j = 0;
    vector<int> ans;
    while(i<n && j<m) {
        if(A[i] < B[j]) {
            i++;
        }
        else if(B[j] < A[j]) {
            j++;
        }
        else {
            ans.push_back(A[i]);
            i++;
            j++;
        }
    }
    return ans;
}
int main () {
    int n, m;
    cin >> n;
    vector<int> A(n);
    for(int i=0; i<n; i++) {
        cin >> A[i];
    }
    cin >> m;
    vector<int> B(m);
    for(int i=0; i<m; i++) {
        cin >> B[i];
    }
    vector<int> result = findArrayIntersection(A, n, B, m);
    for(int x:result) {
        cout << x << " ";
    }
    return 0;
}
#include <bits/stdc++.h>
using namespace std;
string read(int n, vector<int> book, int target) {
    map<int, int> mpp;
    for(int i=0; i<n; i++) {
        int a = book[i];
        int more = target - a;
        if(mpp.find(more) != mpp.end()) {
            return "YES";
        }
        mpp[a] = i;
    }
    return "NO";
}
int main() {
    int n;
    cin >> n;
    vector<int> arr(n);
    for(int i=0; i<n; i++) {
        cin >> arr[i];
    }
    int target;
    cin >> target;
    cout << read(n, arr, target);
    
    return 0;
}